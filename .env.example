# Environment Variables for Docker Development
# Copy this file to .env and configure for your environment

# ==========================================
# NODE ENVIRONMENT
# ==========================================
NODE_ENV=development

# ==========================================
# MONGODB CONFIGURATION
# ==========================================
# MongoDB credentials
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB=projecthub

# MongoDB URI (automatically constructed from above in docker-compose)
# Or provide full URI:
# MONGO_URI=mongodb://admin:password@mongodb:27017/projecthub

# ==========================================
# BACKEND SERVER
# ==========================================
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# Backend URL for frontend (used inside container)
VITE_API_URL=http://backend:5000/api

# ==========================================
# CORS CONFIGURATION
# ==========================================
CLIENT_URL=http://localhost:3000
SOCKET_IO_CORS=http://localhost:3000

# ==========================================
# PRODUCTION DEPLOYMENT
# ==========================================
# Uncomment and configure for production deployment
# NODE_ENV=production
# MONGO_URI=your_production_mongodb_uri
# JWT_SECRET=your_production_jwt_secret
# CLIENT_URL=https://your-frontend-domain.com
# SOCKET_IO_CORS=https://your-frontend-domain.com
# VITE_API_URL=https://your-backend-domain.com/api
